@includeC("redbuild.h")
@includeC("syscalls/syscalls.h")

bool uno(literal source_file) {
    if (not make_run("~/redlib","cross")) { return false; }
    
    new_module("uno");
    if (source_file) {
        set_name("uno_demo");
    } else {
        set_name("uno");
    }
    
    // debug();
    
    if (source_file){
        set_package_type(package_red);
    } else {
        set_package_type(package_lib);
    }
    set_target(target_redacted);
    
    source("doc.c");
    source("uno.c");
    if (source_file) { source(source_file); }
    
    if (compile()){
        gen_compile_commands(source_file);
        if (source_file) {
            run();
        }
    }
}

int main(int argc, strarr argv) {
    parse_arguments(argc,argv);
    defer emit_compile_commands();
    rebuild_self(true);
    return not uno(0);
}